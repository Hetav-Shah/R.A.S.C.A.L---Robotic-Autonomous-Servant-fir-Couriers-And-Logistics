## 📊 Parsing Status Messages

### Example Parsing (Pseudocode)

```python
def parse_status(message):
    # Remove "STATUS:" prefix
    data = message.replace("STATUS:", "")
    
    # Split by pipe
    fields = data.split("|")
    
    status = {
        "mode": fields[0],
        "gps_valid": fields[1] != "NO_GPS",
        "satellites": int(fields[2].split(":")[1]),
        "heading": float(fields[3].split(":")[1])
    }
    
    if status["gps_valid"]:
        lat, lon = fields[1].split(",")
        status["latitude"] = float(lat)
        status["longitude"] = float(lon)
    
    if status["mode"] == "AUTO" and len(fields) > 4:
        wp_lat, wp_lon = fields[4].split(":")[1].split(",")
        status["waypoint_lat"] = float(wp_lat)
        status["waypoint_lon"] = float(wp_lon)
        status["distance"] = float(fields[5].split(":")[1])
    
    return status
```

