## 📚 Reference Implementation

### Python Example (Desktop Testing)

```python
import serial
import time

class RASCALController:
    def __init__(self, port):
        self.serial = serial.Serial(port, 9600, timeout=1)
        time.sleep(2)  # Wait for Arduino reset
        
    def send_command(self, cmd):
        self.serial.write(f"{cmd}\n".encode())
        print(f"Sent: {cmd}")
    
    def forward(self):
        self.send_command("FWD")
    
    def backward(self):
        self.send_command("BWD")
    
    def turn_left(self):
        self.send_command("LEFT")
    
    def turn_right(self):
        self.send_command("RIGHT")
    
    def stop(self):
        self.send_command("STOP")
    
    def goto(self, lat, lon):
        self.send_command(f"GOTO:{lat},{lon}")
    
    def get_position(self):
        self.send_command("POS")
    
    def read_response(self):
        if self.serial.in_waiting:
            return self.serial.readline().decode().strip()
        return None

# Usage
robot = RASCALController('/dev/ttyUSB0')  # or COM3 on Windows

robot.forward()
time.sleep(2)
robot.stop()

robot.goto(37.7750, -122.4195)

while True:
    msg = robot.read_response()
    if msg:
        print(f"Received: {msg}")
        if msg == "WAYPOINT:REACHED":
            break
    time.sleep(0.1)
```

